{
  "name": "industrial-control",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"{src,tests,docs}/**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "analyze": "vite build --sourcemap",
    "release": "standard-version",
    "setup:ollama": "powershell -NoProfile -ExecutionPolicy Bypass -File setup-ollama.ps1",
    "setup:ollama:mac": "bash setup-ollama.sh",
    "start": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "start:local": "npm run start & ollama serve"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/vite": "^4.1.14",
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-session": "^1.17.3",
    "firebase": "^12.12.1",
    "http-proxy-middleware": "^4.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mqtt": "^5.15.1",
    "peerjs": "^1.5.5",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-webcam": "^7.2.0",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "vite": "^6.2.3",
    "ws": "^8.20.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@use-gesture/react": "^10.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.6"
  }
}
