rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidMachine(data) {
      return data.keys().hasAll(['type', 'positionX', 'positionY', 'positionZ', 'userId']) &&
             data.keys().size() == 5 &&
             data.type is string && data.type.size() <= 64 &&
             data.positionX is number &&
             data.positionY is number &&
             data.positionZ is number &&
             data.userId is string && data.userId == request.auth.uid;
    }

    match /users/{userId} {
      match /machines/{machineId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        
        allow create: if isSignedIn() && 
                         isValidId(machineId) && 
                         request.auth.uid == userId && 
                         isValidMachine(incoming());

        allow update: if isSignedIn() &&
                         isValidId(machineId) &&
                         request.auth.uid == userId &&
                         isValidMachine(incoming()) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['type', 'positionX', 'positionY', 'positionZ', 'userId']) &&
                         incoming().userId == existing().userId;

        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
